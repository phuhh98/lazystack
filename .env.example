# Optional: override signaling server URLs (comma-separated WebSocket URLs)
# Local dev auto-uses ws://localhost:4444 when unset — run `npm run signaling` to start it
# Self-hosted example: VITE_SIGNALING_URLS=wss://signaling.myapp.com
# Production default (leave empty): uses public y-webrtc fly.dev servers
#   wss://y-webrtc-signaling-eu.fly.dev, wss://y-webrtc-signaling-us.fly.dev
VITE_SIGNALING_URLS=
